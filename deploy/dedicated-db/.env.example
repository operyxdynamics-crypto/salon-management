# Copy to .env on the customer's VPS, then set a real password:
#   openssl rand -base64 24
#
# This password goes into exactly two other places, and nowhere else:
#   1. The customer's Vercel project (DATABASE_URL / DIRECT_URL)
#   2. The platform admin's "Their own database" card (sealed on save)
POSTGRES_PASSWORD=change-me-before-first-start

# Nightly dumps to keep on disk. 14 ≈ two weeks of undo.
BACKUP_KEEP=14
