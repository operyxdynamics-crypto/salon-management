model Attendance {
  id             String    @id @default(cuid())
  staffId        String
  staff          Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branchId       String?
  branch         Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  clockIn        DateTime
  clockOut       DateTime?
  /// PENDING until someone with staff rights approves. A check-in is never blocked - work starts
  /// whether or not the paperwork is right - but only an APPROVED one counts towards pay.
  status         String    @default("APPROVED")
  source         String    @default("CLOCK")
  note           String?

  /// Where the person was when they clocked in, as their device reported it.
  ///
  /// Recorded rather than trusted. Phone GPS can be spoofed and is unreliable indoors, so this is
  /// evidence for a human to weigh - which is exactly why an off-site check-in goes to approval
  /// instead of being silently rejected or silently accepted.
  latitude       Decimal?  @db.Decimal(10, 7)
  longitude      Decimal?  @db.Decimal(10, 7)
  /// The device's own claimed accuracy, in metres. A 2km accuracy reading means the coordinates
  /// are worthless, and the reviewer should see that rather than a confident-looking distance.
  accuracyMeters Int?
  /// Distance from the branch at check-in. Null when the device gave no location at all.
  distanceMeters Int?
  /// ON_SITE inside the branch geofence, OFF_SITE outside it or with no location. Field work is not
  /// a separate mode someone has to remember to switch on: being elsewhere is what makes it field
  /// work, and the same approval catches both that and a spoofed location.
  kind           String    @default("ON_SITE")
  /// Minutes past the shift start, after the branch's grace period. Zero when on time or when there
  /// is no shift rostered to be late for.
  lateMinutes    Int       @default(0)

  reviewedById   String?
  reviewedBy     User?     @relation("AttendanceReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?

  idempotencyKey String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([branchId, clockIn])
  @@index([staffId, clockIn])
  /// The approvals queue reads this constantly.
  @@index([branchId, status])
}

