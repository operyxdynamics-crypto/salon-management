model Invoice {
  id              String          @id @default(cuid())
  number          String          @unique
  branchId        String
  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customerId      String
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  appointmentId   String?         @unique
  appointment     Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  /// Who supplied this sale, and under which GST registration.
  ///
  /// The name, GSTIN, and state code are snapshotted rather than read through the relations, for
  /// the same reason unitPrice and hsnCode are: an invoice is a legal record of a specific supply
  /// on a specific day. Re-pointing a branch at a different entity or registration next year must
  /// not rewrite last year's invoices.
  legalEntityId      String?
  legalEntity        LegalEntity?     @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  gstRegistrationId  String?
  gstRegistration    GstRegistration? @relation(fields: [gstRegistrationId], references: [id], onDelete: SetNull)
  supplierName       String?
  supplierGstin      String?
  supplierStateCode  String?
  /// Where the supply happened. For a salon this is the branch's state, so tax splits into
  /// CGST and SGST. Comparing it with supplierStateCode is what decides CGST/SGST versus IGST.
  placeOfSupplyState String?

  subtotal        Decimal         @db.Decimal(12, 2)
  discount        Decimal         @default(0) @db.Decimal(12, 2)
  tax             Decimal         @db.Decimal(12, 2)
  taxMode         InvoiceTaxMode  @default(GST)
  tip             Decimal         @default(0) @db.Decimal(12, 2)
  total           Decimal         @db.Decimal(12, 2)
  status          InvoiceStatus   @default(PAID)
  type            InvoiceType     @default(SALE)
  idempotencyKey  String?         @unique
  payments        PaymentRecord[]
  lines           InvoiceLine[]
  parentInvoiceId String?
  parentInvoice   Invoice?        @relation("InvoiceRefunds", fields: [parentInvoiceId], references: [id], onDelete: SetNull)
  refundInvoices  Invoice[]       @relation("InvoiceRefunds")
  voidReason      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model InvoiceLine {
  id                 String          @id @default(cuid())
  invoiceId          String
  invoice            Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type               InvoiceLineType
  description        String
  serviceId          String?
  inventoryItemId    String?
  staffId            String?
  staff              Staff?          @relation(fields: [staffId], references: [id], onDelete: SetNull)
  quantity           Decimal         @db.Decimal(10, 2)
  unitPrice          Decimal         @db.Decimal(12, 2)
  discount           Decimal         @default(0) @db.Decimal(12, 2)
  taxRate            Decimal         @db.Decimal(5, 2)
  /// HSN (goods) or SAC (services) code, snapshotted at the moment of sale.
  ///
  /// Stored on the line, not read through the tax class, for the same reason `unitPrice` and
  /// `taxRate` are: an invoice is a legal record of what was billed that day. Re-pointing a
  /// product at a different tax class next month must not rewrite last month's invoices.
  hsnCode            String?
  priceTaxMode       TaxPricingMode  @default(EXCLUSIVE)
  tax                Decimal         @db.Decimal(12, 2)
  total              Decimal         @db.Decimal(12, 2)
  refundSourceLineId String?
  refundSourceLine   InvoiceLine?    @relation("InvoiceLineRefunds", fields: [refundSourceLineId], references: [id], onDelete: SetNull)
  refundLines        InvoiceLine[]   @relation("InvoiceLineRefunds")

  @@index([refundSourceLineId])
}

