/// ---------------------------------------------------------------------------------------------
/// Operyx's own business: the salons we are selling to, before and after they become tenants.
/// ---------------------------------------------------------------------------------------------

/**
 * A sales enquiry.
 *
 * Exists because a prospect is not a tenant. Someone who calls about pricing has no salon in the
 * system, no owner login and no subscription - and if the only way to record them is to create a
 * tenant, the database fills with half-real salons that skew every count. A lead converts into a
 * tenant exactly once, at which point `convertedTenantId` links the two and the pipeline number
 * stops counting them.
 */
model Lead {
  id           String     @id @default(cuid())
  salonName    String
  contactName  String
  phone        String
  email        String?
  city         String?
  /// Roughly how big they are, so a salesperson can tell a chair-rental from a chain at a glance.
  branchCount  Int        @default(1)
  staffCount   Int        @default(0)
  /// Where they came from: referral, Instagram, walk-in, cold call. Free text on purpose - the
  /// list of channels changes faster than a schema should.
  source       String?
  status       LeadStatus @default(NEW)
  /// The plan being discussed, so a quote can be reproduced later.
  interestedPlanId String?
  interestedPlan   SubscriptionPlan? @relation(fields: [interestedPlanId], references: [id], onDelete: SetNull)
  notes        String?
  /// When to chase. The work queue reads this - a lead with no next step is a lead being lost.
  followUpAt   DateTime?
  ownerUserId  String?
  owner        User?      @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  /// Set once the lead becomes a real salon. Also what stops it being counted as open pipeline.
  convertedTenantId String? @unique
  convertedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status, followUpAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  DEMO_BOOKED
  QUOTED
  WON
  LOST
}
