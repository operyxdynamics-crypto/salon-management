generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLATFORM_ADMIN
  OWNER
  MANAGER
  RECEPTIONIST
  STYLIST
  ACCOUNTANT
  CUSTOMER
}

enum TenantStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BranchPublicationStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  ARCHIVED
}

enum VerificationDocumentType {
  GST_CERTIFICATE
  PAN_CARD
  ADDRESS_PROOF
  BANK_PROOF
  SALON_MEDIA
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_SERVICE
  COMPLETED
  CANCELLED
  NO_SHOW
  WAITLISTED
}

enum AppointmentSource {
  MARKETPLACE
  SALON_WEBSITE
  PHONE
  WALK_IN
  STAFF_CREATED
}

enum WebsitePageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  GIFT_CARD
  PACKAGE
  LOYALTY
  WALLET
}

enum InvoiceStatus {
  DRAFT
  PAID
  PARTIALLY_PAID
  PARTIALLY_REFUNDED
  REFUNDED
  VOID
}

enum InvoiceType {
  SALE
  REFUND
}

enum InvoiceTaxMode {
  GST
  NON_GST
}

enum TaxPricingMode {
  EXCLUSIVE
  INCLUSIVE
}

enum InvoiceLineType {
  SERVICE
  PRODUCT
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model Tenant {
  id                        String                     @id @default(cuid())
  name                      String
  slug                      String                     @unique
  legalName                 String?
  gstin                     String?
  status                    TenantStatus               @default(DRAFT)
  subscription              String                     @default("growth")
  panNumber                 String?
  onboardingStep            Int                        @default(1)
  policies                  Json?
  branches                  Branch[]
  users                     User[]
  services                  Service[]
  serviceCategories         ServiceCategory[]
  customers                 Customer[]
  saleDrafts                SaleDraft[]
  inventoryItems            InventoryItem[]
  vendors                   Vendor[]
  productCategories         ProductCategory[]
  brands                    Brand[]
  unitsOfMeasure            UnitOfMeasure[]
  taxClasses                TaxClass[]
  expenseCategories         ExpenseCategory[]
  coupons                   Coupon[]
  legalEntities             LegalEntity[]
  roles                     Role[]
  serviceConsumptionRecipes ServiceConsumptionRecipe[]
  campaigns                 Campaign[]
  memberships               Membership[]
  packages                  Package[]
  rewardRules               RewardRule[]
  benefitTransactions       BenefitTransaction[]
  subscriptionRecord        TenantSubscription?
  subscriptionEvents        SubscriptionEvent[]
  verificationDocuments     VerificationDocument[]
  adminNotes                AdminNote[]
  ownerInvitations          OwnerInvitation[]
  website                   SalonWebsite?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
}

model Branch {
  id                    String                     @id @default(cuid())
  tenantId              String
  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String
  slug                  String
  phone                 String?
  email                 String?
  address               String
  city                  String
  state                 String
  postalCode            String
  latitude              Decimal?                   @db.Decimal(10, 7)
  longitude             Decimal?                   @db.Decimal(10, 7)
  timezone              String                     @default("Asia/Kolkata")
  /// The branch's invoice series code, e.g. "WHF". Unique per salon, because it is what keeps two
  /// branches from issuing the same invoice number. Kept to 4 characters so the finished serial
  /// stays inside the 16-character limit GST allows.
  invoiceCode           String?

  /// How close to the branch a person must be for a check-in to count as on-site. Consumer GPS is
  /// good to roughly 10-50m outdoors and far worse inside a building, so this is deliberately
  /// generous - a radius tighter than the error margin just rejects honest staff.
  geofenceRadiusMeters  Int                        @default(150)
  /// Minutes after shift start that still count as on time. Zero means any lateness needs approval.
  /// Kept as a setting because the right answer is a management decision, not a code decision.
  lateGraceMinutes      Int                        @default(0)

  ownershipModel        BranchOwnershipModel       @default(COCO)
  /// Who owns the asset. Affects franchise economics, not invoicing.
  ownerEntityId         String?
  ownerEntity           LegalEntity?               @relation("BranchOwner", fields: [ownerEntityId], references: [id], onDelete: SetNull)
  /// Who runs the branch - and therefore who supplies the service and issues the invoice.
  /// This single field decides whose name and GSTIN appears on every bill.
  operatorEntityId      String?
  operatorEntity        LegalEntity?               @relation("BranchOperator", fields: [operatorEntityId], references: [id], onDelete: SetNull)
  /// The registration invoices are raised under. Must belong to the operator entity and match
  /// this branch's state; enforced in application code, as Prisma cannot express the rule.
  gstRegistrationId     String?
  gstRegistration       GstRegistration?           @relation(fields: [gstRegistrationId], references: [id], onDelete: SetNull)

  isPublished           Boolean                    @default(false)
  publicationStatus     BranchPublicationStatus    @default(DRAFT)
  profileDescription    String?
  policies              Json?
  submittedAt           DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  suspendedAt           DateTime?
  rating                Decimal                    @default(0) @db.Decimal(2, 1)
  reviewCount           Int                        @default(0)
  staff                 Staff[]
  appointments          Appointment[]
  blockedTimes          BlockedTime[]
  saleDrafts            SaleDraft[]
  resources             Resource[]
  invoices              Invoice[]
  stock                 BranchStock[]
  reviews               Review[]
  operatingHours        OperatingHour[]
  expenses              Expense[]
  invoiceSequences      InvoiceSequence[]
  stockMovements        StockMovement[]
  purchaseEntries       PurchaseEntry[]
  stockTransfersFrom    StockTransfer[]            @relation("StockTransferFrom")
  stockTransfersTo      StockTransfer[]            @relation("StockTransferTo")
  stocktakes            Stocktake[]
  verificationDocuments VerificationDocument[]
  reviewsHistory        BranchReview[]
  publicationHistory    BranchPublicationHistory[]
  staffAssignments      StaffBranchAssignment[]
  branchServices        BranchService[]
  shifts                Shift[]
  attendance            Attendance[]
  registerSessions      RegisterSession[]
  giftCards             GiftCard[]
  benefitTransactions   BenefitTransaction[]

  @@unique([tenantId, slug])
  /// Two branches in the same salon must never share an invoice series.
  @@unique([tenantId, invoiceCode])
  @@index([operatorEntityId])
  @@index([gstRegistrationId])
}

model User {
  id                  String                 @id @default(cuid())
  tenantId            String?
  tenant              Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email               String?                @unique
  phone               String?                @unique
  passwordHash        String?
  name                String
  /// Legacy coarse role. Kept because platform-level checks (PLATFORM_ADMIN, CUSTOMER) still use
  /// it and because it is the fallback when `roleId` is null. Tenant rights now come from `role`.
  role                UserRole
  /// The tenant role that grants this person's rights.
  roleId              String?
  roleRecord          Role?                  @relation(fields: [roleId], references: [id], onDelete: SetNull)
  /// Rights added to or removed from this one person, on top of their role.
  permissionOverrides UserPermission[]
  isActive            Boolean                @default(true)
  staff               Staff?
  customers           Customer[]
  auditLogs           AuditLog[]
  saleDrafts          SaleDraft[]            @relation("SaleDraftCreatedBy")
  blockedTimes        BlockedTime[]          @relation("BlockedTimeCreatedBy")
  uploadedDocuments   VerificationDocument[] @relation("DocumentUploader")
  reviewedDocuments   VerificationDocument[] @relation("DocumentReviewer")
  reviewedAttendance  Attendance[]           @relation("AttendanceReviewer")
  ownedLeads          Lead[]                 @relation("LeadOwner")
  subscriptionEvents  SubscriptionEvent[]    @relation("SubscriptionEventActor")
  branchReviews       BranchReview[]
  adminNotes          AdminNote[]
  sentInvitations     OwnerInvitation[]      @relation("InvitationSender")
  dashboardPreference DashboardPreference?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model Staff {
  id                      String                   @id @default(cuid())
  userId                  String                   @unique
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId                String
  branch                  Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  jobTitle                String
  bio                     String?
  commissionRate          Decimal                  @default(0) @db.Decimal(5, 2)
  /// Fixed monthly pay, before commission and tips. Zero means this person earns on commission
  /// only, which is a real arrangement in salons - not a missing value.
  monthlySalary           Decimal                  @default(0) @db.Decimal(10, 2)
  services                StaffService[]
  appointments            Appointment[]
  shifts                  Shift[]
  attendance              Attendance[]
  commissions             Commission[]
  leaves                  StaffLeave[]
  invoiceLines            InvoiceLine[]
  appointmentServiceLines AppointmentServiceLine[]
  branchAssignments       StaffBranchAssignment[]
  blockedTimes            BlockedTime[]
}

model StaffBranchAssignment {
  id               String   @id @default(cuid())
  staffId          String
  staff            Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isPrimary        Boolean  @default(false)
  canManageWebsite Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@unique([staffId, branchId])
  @@index([branchId])
}

model Customer {
  id                  String               @id @default(cuid())
  tenantId            String?
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  name                String
  phone               String
  email               String?
  birthday            DateTime?
  notes               String?
  preferences         Json?
  allergies           String?
  tags                String[]             @default([])
  isArchived          Boolean              @default(false)
  whatsappConsent     Boolean              @default(false)
  smsConsent          Boolean              @default(false)
  emailConsent        Boolean              @default(false)
  walletBalance       Decimal              @default(0) @db.Decimal(12, 2)
  appointments        Appointment[]
  invoices            Invoice[]
  saleDrafts          SaleDraft[]
  loyaltyLedger       LoyaltyLedger[]
  customerMemberships CustomerMembership[]
  packagePurchases    PackagePurchase[]
  reviews             Review[]
  giftCards           GiftCard[]
  benefitTransactions BenefitTransaction[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([tenantId, phone])
  @@index([userId])
}

model Service {
  id                 String                     @id @default(cuid())
  tenantId           String
  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  /// Deprecated. `categoryId` is the source of truth; this string is dropped once every
  /// read (POS filters especially) uses the relation.
  category           String
  categoryId         String?
  categoryRecord     ServiceCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  /// SAC code and GST rate for this service.
  taxClassId         String?
  taxClass           TaxClass?                  @relation(fields: [taxClassId], references: [id], onDelete: SetNull)
  description        String?
  durationMinutes    Int
  price              Decimal                    @db.Decimal(10, 2)
  /// Resolved snapshot of the tax class rate at the time of sale.
  taxRate            Decimal                    @default(18) @db.Decimal(5, 2)
  priceTaxMode       TaxPricingMode             @default(EXCLUSIVE)
  isActive           Boolean                    @default(true)
  onlineBooking      Boolean                    @default(true)
  bufferBefore       Int                        @default(0)
  bufferAfter        Int                        @default(0)
  sortOrder          Int                        @default(0)
  staff              StaffService[]
  appointments       Appointment[]
  branches           BranchService[]
  appointmentLines   AppointmentServiceLine[]
  consumptionRecipes ServiceConsumptionRecipe[]

  @@index([categoryId])
}

/// Master data.
///
/// Every master is tenant-scoped, manually sortable, and archived rather than deleted -
/// historical invoices, stock movements, and expenses point at these rows, so a hard delete
/// would either break referential integrity or silently rewrite history.

enum TaxClassKind {
  GOODS
  SERVICE
}

enum LegalEntityType {
  COMPANY
  FRANCHISEE
}

/// A named set of rights.
///
/// System roles (Owner, Manager, Receptionist, Stylist, Accountant) are seeded per tenant and
/// locked: an owner who could edit "Owner" could remove their own right to manage roles and lock
/// themselves out of their salon permanently. To customise, they clone one.
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Stable identifier for the seeded roles: OWNER, MANAGER, RECEPTIONIST, STYLIST, ACCOUNTANT.
  /// Null for roles the salon created itself.
  code        String?
  name        String
  description String?
  /// Locked. Cannot be edited or deleted; can be cloned.
  isSystem    Boolean  @default(false)
  /// The permission strings from src/lib/permissions.ts.
  permissions String[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// A single right added to, or taken away from, one person - on top of whatever their role gives.
///
/// `allow` is explicit rather than implied, because "Priya is a receptionist but may also give
/// refunds" and "Ravi is a manager but must not see payroll" are both things an owner will want to
/// say, and a grant-only list can express only the first.
model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String
  allow      Boolean
  createdAt  DateTime @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

enum BranchOwnershipModel {
  /// Company owns the asset, company runs it. The company invoices.
  COCO
  /// Franchisee owns the asset, company runs it. The company still invoices.
  FOCO
  /// Franchisee owns and runs it, and invoices under its own GSTIN.
  FOFO
}

/// A registered business.
///
/// The tenant always has exactly one COMPANY entity. Each franchisee that bills under its own
/// name is a separate entity, because a FOFO franchisee is a different company with its own PAN
/// and GSTIN - its invoices are its own, and its revenue is not the parent company's revenue.
model LegalEntity {
  id               String            @id @default(cuid())
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type             LegalEntityType
  /// Trading name, e.g. "Lumiere Studio".
  name             String
  /// Name on the PAN, printed on invoices, e.g. "Lumiere Beauty Pvt Ltd".
  legalName        String
  panNumber        String?
  cin              String?
  email            String?
  phone            String?
  /// The tenant's own company, as opposed to a franchisee.
  isPrimary        Boolean           @default(false)
  isActive         Boolean           @default(true)

  registrations    GstRegistration[]
  ownedBranches    Branch[]          @relation("BranchOwner")
  operatedBranches Branch[]          @relation("BranchOperator")
  invoices         Invoice[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tenantId, type])
}

/// One GSTIN.
///
/// GST registration in India is state-wise: one legal entity gets one GSTIN per state. Two
/// branches in the same state share a registration; a branch in another state needs its own,
/// and that is mandatory rather than optional. Input tax credit is claimed against the GSTIN
/// that received the supply, which is why purchases point here and not at the company.
model GstRegistration {
  id            String          @id @default(cuid())
  legalEntityId String
  legalEntity   LegalEntity     @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  gstin         String
  /// "Karnataka"
  state         String
  /// "29" - the first two digits of the GSTIN. Decides CGST/SGST versus IGST.
  stateCode     String
  /// Principal place of business for this registration.
  address       String?
  isActive      Boolean         @default(true)

  branches      Branch[]
  invoices      Invoice[]
  purchases     PurchaseEntry[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([legalEntityId, state])
  @@unique([gstin])
}

enum DiscountType {
  PERCENT
  FLAT
}

/// A bill-level discount code redeemed at the POS.
///
/// Redemptions are a separate table, not a counter, for two reasons: the usage cap must be
/// enforced inside the checkout transaction (two receptionists can race for the last use), and
/// a refund has to give the customer their coupon back - which is impossible without a row to
/// reverse.
model Coupon {
  id                 String             @id @default(cuid())
  tenantId           String
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// What reception types at the POS, e.g. "MONSOON20".
  code               String
  name               String
  description        String?

  discountType       DiscountType
  discountValue      Decimal            @db.Decimal(10, 2)
  /// Ceiling on a percent discount, e.g. "20% off, up to 500".
  maxDiscountAmount  Decimal?           @db.Decimal(10, 2)
  /// The bill must reach this before the coupon applies.
  minBillAmount      Decimal?           @db.Decimal(10, 2)

  startsAt           DateTime?
  endsAt             DateTime?
  /// Total redemptions allowed across all customers. Null means unlimited.
  maxRedemptions     Int?
  /// Redemptions allowed per customer. Null means unlimited.
  maxPerCustomer     Int?
  newCustomersOnly   Boolean            @default(false)

  /// Empty restriction lists mean the coupon applies to the whole bill.
  serviceIds         String[]
  productIds         String[]
  serviceCategoryIds String[]
  productCategoryIds String[]
  /// Empty means every branch.
  branchIds          String[]

  isActive           Boolean            @default(true)
  redemptions        CouponRedemption[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  invoiceId  String   @unique
  customerId String
  /// The rupee amount actually taken off. Needed for reporting and refund reversal.
  amount     Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  @@index([couponId])
  @@index([customerId])
}

model ProductCategory {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  description String?
  color       String?
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  products    InventoryItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, sortOrder])
}

model Brand {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  description String?
  color       String?
  logoUrl     String?
  /// The distributor who supplies this brand, when the salon buys it from one vendor.
  vendorId    String?
  vendor      Vendor?         @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  products    InventoryItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, sortOrder])
  @@index([vendorId])
}

model UnitOfMeasure {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Display name, e.g. "Millilitre".
  name           String
  /// Short form shown on the POS and invoices, e.g. "ml".
  code           String
  /// Pieces cannot be sold or consumed as 0.5; millilitres can.
  allowsFraction Boolean         @default(true)
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  products       InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, sortOrder])
}

/// HSN (goods) / SAC (services) code with its GST rate.
///
/// Indian GST invoices are required to carry these codes. The rate here is the default that
/// a service or product inherits; the invoice line still snapshots the rate that applied on
/// the day it was billed, because a later rate change must not rewrite past invoices.
model TaxClass {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  /// HSN "3305" or SAC "999721".
  code        String
  kind        TaxClassKind
  rate        Decimal         @default(18) @db.Decimal(5, 2)
  description String?
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  services    Service[]
  products    InventoryItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, kind])
}

model ExpenseCategory {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  description String?
  color       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  expenses    Expense[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, sortOrder])
}

model ServiceCategoryTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceCategory {
  id                   String    @id @default(cuid())
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  copiedFromTemplateId String?
  name                 String
  description          String?
  color                String?
  icon                 String?
  sortOrder            Int       @default(0)
  isActive             Boolean   @default(true)
  services             Service[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, sortOrder])
}

model BranchService {
  branchId        String
  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceId       String
  service         Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isActive        Boolean         @default(true)
  price           Decimal?        @db.Decimal(10, 2)
  durationMinutes Int?
  taxRate         Decimal?        @db.Decimal(5, 2)
  priceTaxMode    TaxPricingMode?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@id([branchId, serviceId])
  @@index([serviceId])
}

model StaffService {
  staffId   String
  serviceId String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

model Resource {
  id           String        @id @default(cuid())
  branchId     String
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name         String
  type         String
  appointments Appointment[]
  blockedTimes BlockedTime[]
}

model BlockedTime {
  id          String    @id @default(cuid())
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  staffId     String?
  staff       Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  resourceId  String?
  resource    Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?     @relation("BlockedTimeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  title       String
  reason      String?
  startsAt    DateTime
  endsAt      DateTime
  isAllDay    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([branchId, startsAt, endsAt])
  @@index([staffId, startsAt, endsAt])
  @@index([resourceId, startsAt, endsAt])
}

model Appointment {
  id                 String                     @id @default(cuid())
  branchId           String
  branch             Branch                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
